<section id="contact" class="w-full bg-gradient-to-r from-[#bfbfbf] to-[#808080] text-black py-20 px-8 md:px-16">
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">

    <!-- Left: Text Content -->
    <div class="space-y-6">
      <h2 class="text-4xl md:text-5xl font-extrabold leading-tight">
        Let’s <span class="text-pink-900">Connect</span>
      </h2>
      <p class="text-black text-base md:text-lg font-light max-w-xl">
        Whether you're vibing with my work, planning something dope, or just wanna say hey — my inbox is always open.
      </p>
      <p class="text-black text-base md:text-lg font-light max-w-xl">
        Slide into my DMs, shoot an email, or fill the form. I reply faster than your crush sees your text 👀
      </p>
    </div>

    <!-- Right: Contact Form -->
    <form action="https://formspree.io/f/xkgryjyl" method="POST" class="space-y-4 max-w-lg w-full">
      <input
        type="text"
        name="name"
        placeholder="Your Name"
        required
        class="w-full bg-white border border-black/30 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-pink-900 text-black placeholder:text-gray-600"
      />

      <input
        type="email"
        name="email"
        placeholder="Your Email"
        required
        class="w-full bg-white border border-black/30 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-pink-900 text-black placeholder:text-gray-600"
      />

      <textarea
        name="message"
        rows="5"
        placeholder="Your Message"
        required
        class="w-full bg-white border border-black/30 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-pink-900 text-black placeholder:text-gray-600"
      ></textarea>

      <button
        type="submit"
        class="bg-pink-900 hover:bg-pink-800 transition duration-300 rounded-lg px-6 py-3 text-white font-semibold"
      >
        Send It
      </button>
    </form>

  </div>
</section>

